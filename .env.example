# ─────────────────────────────────────────────
#  CONFIGURACIÓN DE ENTORNO - Nubez (PLANTILLA)
#  Copiá este archivo como .env y completá los valores reales.
#  NO pongas secretos reales acá: .env.example se commitea, .env no.
# ─────────────────────────────────────────────

# Google Sheets
GOOGLE_SHEET_ID=tu_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=cuenta-servicio@tu-proyecto.iam.gserviceaccount.com
# La clave privada va entre comillas y con los saltos de línea como \n literales
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...reemplazar...IDAQAB\n-----END PRIVATE KEY-----\n"

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AA...reemplazar...
TELEGRAM_CHAT_ID=000000000

# Servidor
PORT=3000

# API key para clientes externos (header: Authorization: Bearer <key>) → POST /api/movimiento
# Generala con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NUBEZ_API_KEY=reemplazar_por_una_key_larga_y_aleatoria
